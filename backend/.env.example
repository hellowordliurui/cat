# PRD 3.2 后端数据库（可选，未设置时使用内存/mock）
# PostgreSQL：禁忌清单、用户账户（使用 Supabase PostgreSQL）
# 在 Supabase 控制台：Project Settings → Database → Connection string → URI，复制后替换 [YOUR-PASSWORD]
# DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
# 或 Session 模式（直连）：postgresql://postgres:[YOUR-PASSWORD]@db.[project-ref].supabase.co:5432/postgres

# MongoDB：已审计食谱
# MONGODB_URL=mongodb://localhost:27017
# MONGODB_DB=moechef

# Supabase：食谱表 + Storage 封面图。后端上传封面图时用 service_role key 可绕过 RLS
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...   # 仅后端环境变量，严禁暴露到前端
# SUPABASE_STORAGE_BUCKET=recipe-covers

# PRD 3.3：豆包（火山方舟）- 文本生成与生图，在 https://console.volcengine.com/ark 创建 API Key
# DOUBAO_API_KEY=your_api_key_here
# 生图可用同一 Key，或单独配置：
# DOUBAO_IMAGE_API_KEY=your_image_api_key_here
# DOUBAO_CHAT_MODEL=doubao-pro-32k
# DOUBAO_IMAGE_MODEL=doubao-seedream-4-0-250828
# 封面图提示词：1/true 时用豆包文本模型根据步骤+食材生成（更准），否则用规则拼接
# USE_LLM_COVER_PROMPT=1
